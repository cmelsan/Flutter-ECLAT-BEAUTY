# ── ÉCLAT Beauty - Environment Variables ────────────────────────

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe ────────────────────────────────────────────────────
# Use test keys for development
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key-here

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name

# ── Brevo (Email) ─────────────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key

# ── Backend API ───────────────────────────────────────────────
SITE_URL=http://localhost:4321

# ── Notes ─────────────────────────────────────────────────────
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env to version control
# 3. Get Supabase keys from: https://app.supabase.com/project/_/settings/api
# 4. Get Stripe keys from: https://dashboard.stripe.com/test/apikeys
